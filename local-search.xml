an> defaultCollapseClass = isLargeCode ? <span class="hljs-string">&#x27;collapse&#x27;</span> : <span class="hljs-string">&#x27;collapse show&#x27;</span>;    <span class="hljs-comment">// 折叠块包裹原来的内容</span>    <span class="hljs-keyword">var</span> div = <span class="hljs-string">`&lt;div class=&quot;<span class="hljs-subst">$&#123;defaultCollapseClass&#125;</span>&quot; id=&quot;<span class="hljs-subst">$&#123;id&#125;</span>&quot;&gt;<span class="hljs-subst">$&#123;wrapper.innerHTML&#125;</span>&lt;/div&gt;`</span>;    wrapper.<span class="hljs-property">innerHTML</span> = btn + span + div;    <span class="hljs-comment">// 如果代码行数超过30行，为折叠按钮添加点击事件</span>    <span class="hljs-keyword">if</span> (isLargeCode) &#123;      <span class="hljs-keyword">var</span> collapseButton = wrapper.<span class="hljs-title function_">querySelector</span>(<span class="hljs-string">&quot;.fa-angle-down&quot;</span>);      collapseButton.<span class="hljs-title function_">addEventListener</span>(<span class="hljs-string">&#x27;click&#x27;</span>, <span class="hljs-keyword">function</span> (<span class="hljs-params"></span>) &#123;        <span class="hljs-keyword">var</span> icon = $(<span class="hljs-variable language_">this</span>);        icon.<span class="hljs-title function_">removeClass</span>(<span class="hljs-string">&#x27;rotate&#x27;</span>);      &#125;);    &#125;  &#125;&#125;$(<span class="hljs-variable language_">document</span>).<span class="hljs-title function_">ready</span>(addLanguage);</code></pre></div><div class="code-wrapper"><pre><code class="hljs javascript"><span class="hljs-keyword">var</span> codeLang = &#123;    <span class="hljs-attr">ABAP</span>: <span class="hljs-string">&quot;ABAP&quot;</span>,    <span class="hljs-attr">APL</span>: <span class="hljs-string">&quot;APL&quot;</span>,    <span class="hljs-attr">ASCIIARMOR</span>: <span class="hljs-string">&quot;ASCII Armor&quot;</span>,    <span class="hljs-title class_">ASN1</span>: <span class="hljs-strin